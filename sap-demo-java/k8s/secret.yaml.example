# Copy to secret.yaml and fill in SAP_API_KEY before applying.
# secret.yaml is gitignored; this example file is not.
#
#   cp k8s/secret.yaml.example k8s/secret.yaml
#   # edit SAP_API_KEY below, then:
#   kubectl apply -f k8s/secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: customer360-secrets
  namespace: sap-demo
  labels:
    app.kubernetes.io/name: customer360
type: Opaque
stringData:
  # SAP Business Accelerator Hub sandbox API key.
  # Get a free one at https://api.sap.com → any API → "Show API Key".
  SAP_API_KEY: "<PASTE_YOUR_SAP_API_KEY_HERE>"

  # Optional — only needed when pointing at a real BTP tenant that uses
  # OAuth2 xsuaa bearer tokens. For the sandbox this stays empty.
  SAP_BEARER_TOKEN: ""
